# GreenCloud Environment Configuration
# Copy this to .env and fill in real values

# Domain (use localhost for local dev, your real domain for production)
DOMAIN=localhost

# Registry (local registry)
REGISTRY_HOST=localhost:5000

# Prod Database
PROD_DB_USER=greencloud
PROD_DB_PASSWORD=changeme_prod
PROD_DB_NAME=greencloud_prod

# Dev Database
DEV_DB_USER=greencloud
DEV_DB_PASSWORD=changeme_dev
DEV_DB_NAME=greencloud_dev

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana

# Carbon Engine
ELECTRICITY_MAPS_API_KEY=
CARBON_ZONE=GB
CARBON_THRESHOLD_LOW=100
CARBON_THRESHOLD_HIGH=300
PI_IDLE_WATTS=4
PI_MAX_WATTS=12

# Cloudflare Tunnel (leave empty for local-only mode)
# Get this from: Cloudflare Zero Trust > Networks > Tunnels > your-tunnel > Token
CLOUDFLARE_TUNNEL_TOKEN=

# Streaming Relay (Neko Virtual Browser)
NEKO_ADMIN_PASSWORD=changeme_neko_admin
NEKO_USER_PASSWORD=changeme_neko_user
NEKO_SCREEN=1920x1080@30
NEKO_NAT_IP=
NEKO_UDP_START=52000
NEKO_UDP_END=52100
NEKO_MEM_LIMIT=2g
NEKO_CPUS=2.0
