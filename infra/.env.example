# GreenCloud Environment Configuration
# Copy this to .env.prod or .env.dev and fill in real values

# Domain (use localhost for local dev)
DOMAIN=localhost

# Registry (local registry once Task 3 is done)
REGISTRY_HOST=localhost:5000

# Prod Database
PROD_DB_USER=greencloud
PROD_DB_PASSWORD=changeme_prod
PROD_DB_NAME=greencloud_prod

# Dev Database
DEV_DB_USER=greencloud
DEV_DB_PASSWORD=changeme_dev
DEV_DB_NAME=greencloud_dev
