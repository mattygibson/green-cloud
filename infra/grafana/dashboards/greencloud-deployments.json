{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Deployment Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total{handler=~\"/deployments.*|/agent/deploy.*\"}[5m])",
          "legendFormat": "{{ handler }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Deployment Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=~\"/deployments.*|/agent/deploy.*\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler=~\"/deployments.*|/agent/deploy.*\"}[5m]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Deployment Status Codes",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/deployments.*|/agent/deploy.*\"}[5m])) by (status)",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "id": 4,
      "title": "Deployment Logs",
      "type": "logs",
      "targets": [
        {
          "expr": "{service=~\"greencloud-api|greencloud-agent\"} |= \"deploy\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["greencloud", "deployments"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "GreenCloud Deployments",
