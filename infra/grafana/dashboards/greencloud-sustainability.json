    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
      "id": 8,
      "title": "Builds Deferred",
      "type": "stat",
      "targets": [
        {
          "expr": "greencloud_builds_deferred_total",
          "legendFormat": "Deferred"
