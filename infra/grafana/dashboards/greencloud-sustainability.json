{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 300 }
            ]
          },
          "unit": "gCO2/kWh"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "title": "Grid Carbon Intensity",
      "type": "gauge",
      "targets": [
        {
          "expr": "greencloud_carbon_intensity_gco2_per_kwh",
          "legendFormat": "{{ zone }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "title": "Carbon Status",
      "description": "0=Low (green), 1=Medium (amber), 2=High (red)",
      "type": "stat",
      "targets": [
        {
          "expr": "greencloud_carbon_status",
          "legendFormat": "Status"
        }
      ],
      "options": {
        "colorMode": "background"
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "watt" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "title": "Power Draw",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(greencloud_power_watts)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "gCO2/kWh" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "title": "Carbon Intensity Timeline",
      "type": "timeseries",
      "targets": [
        {
          "expr": "greencloud_carbon_intensity_gco2_per_kwh",
          "legendFormat": "{{ zone }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "watt" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "title": "Power Usage by Node",
      "type": "timeseries",
      "targets": [
        {
          "expr": "greencloud_power_watts",
          "legendFormat": "{{ node }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "id": 6,
      "title": "Total Emissions (gCO2)",
      "type": "stat",
      "targets": [
        {
          "expr": "greencloud_emissions_gco2_total",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
